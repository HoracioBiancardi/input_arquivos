# Caminho do SQLite local de configuração da aplicação (contexts, usuários, audit log)
APP_CONFIG_DB_PATH=data/app_config.db

# Chave usada para assinar o cookie de sessão do NiceGUI (app.storage.user).
# Gere uma chave aleatória forte em produção, ex.: python -c "import secrets; print(secrets.token_hex(32))"
STORAGE_SECRET=change-me-in-production

# Credenciais do primeiro usuário admin, criado automaticamente no bootstrap
# se a tabela de usuários estiver vazia. Troque a senha após o primeiro login.
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=admin123

# Servidor MinIO compartilhado por todos os contexts (cada context define
# apenas o bucket que deve usar neste mesmo servidor).
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false

# Servidor
HOST=0.0.0.0
PORT=8080
RELOAD=false
